  "version": "2.1.0",
  "name": "Non-interacting density-density response (Lindhard)",
  "domain": "physics-condensed-matter",
  "principles": [
    "RPA",
    "linear response",
    "Fermi-Dirac statistics"
  ],
  "formulaTeX": "\\chi_0(\\mathbf{q}, \\omega) = \\frac{2}{V} \\sum_{\\mathbf{k}, n, m} \\frac{f(\\varepsilon_{n\\mathbf{k}}) - f(\\varepsilon_{m,\\mathbf{k+q}})}{\\omega + \\varepsilon_{n\\mathbf{k}} - \\varepsilon_{m,\\mathbf{k+q}} + i\\eta}",
  "conventions": [
    "Im chi_0(omega > 0) <= 0 — causality",
    "spin factor 2 absorbed (non-magnetic)",
    "q in Cartesian 1/Bohr"
  ],
  "expectedLimits": [
    "Re chi_0(0) < 0 — polarisable system",
    "|chi_0| -> 0 as omega -> infinity",
    "plasmon omega_p envelope set by system (Si DZP: [12, 18] eV)"
  ],
  "references": [
    "Lindhard 1954",
    "Mahan, Many-Particle Physics, ch.5",
    "Adler 1962"
  ],
  "validationEnvelopes": {
    "plasmonOmegaP": [
      12,
      18
    ]
  },
