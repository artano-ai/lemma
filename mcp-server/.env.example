# Postgres connection for the scientific RAG store.
# Required for the rag_lookup tool. Without this, rag_lookup returns a friendly error
# while the other tools (cards_list, cards_get, ops_get, hypothesis_crosscheck) keep working.
LEMMA_RAG_DSN=postgresql://user@localhost:5432/lemma

# Schema that holds the chunks table.
LEMMA_RAG_SCHEMA=lemma

# --- Embedder ---
# Provider: transformers (local, default) or gemini (API).
LEMMA_EMBEDDING_PROVIDER=transformers

# Output dimension. Must match the vector(N) column in the chunks table.
LEMMA_EMBEDDING_DIM=768

# transformers (local) settings — used when provider=transformers
LEMMA_TRANSFORMERS_MODEL=onnx-community/Qwen3-Embedding-0.6B-ONNX
LEMMA_TRANSFORMERS_DTYPE=q8
LEMMA_TRANSFORMERS_POOLING=last_token
LEMMA_TRANSFORMERS_INSTRUCTION=Given a question about scientific computing, retrieve relevant passages from the technical documentation that answer it.

# gemini settings — used when provider=gemini
# LEMMA_GEMINI_API_KEY=
# LEMMA_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
