# Postgres connection for the scientific RAG store.
# Required for the rag_lookup tool. Without this, rag_lookup returns a friendly error
# while the other tools (parse_siesta_fdf, parse_eig_file, generate_slurm) keep working.
ATOMIRA_RAG_DSN=postgresql://you@localhost:5432/atomira_lab

# Schema that holds the chunks table. Default: atomira_lab.
ATOMIRA_RAG_SCHEMA=atomira_lab

# Workspace root for path resolution. Tools that take a `path` argument resolve it
# relative to this directory. Default: process.cwd().
# ATOMIRA_WORKSPACE=/path/to/your/project

# --- Embedder ---
# Provider: transformers (local, default) or gemini (API).
ATOMIRA_EMBEDDING_PROVIDER=transformers

# Output dimension. Must match the vector(N) column in the chunks table.
ATOMIRA_EMBEDDING_DIM=768

# transformers (local) settings — used when provider=transformers
ATOMIRA_TRANSFORMERS_MODEL=onnx-community/Qwen3-Embedding-0.6B-ONNX
ATOMIRA_TRANSFORMERS_DTYPE=q8
ATOMIRA_TRANSFORMERS_POOLING=last_token
ATOMIRA_TRANSFORMERS_INSTRUCTION=Given a question about scientific computing, retrieve relevant passages from the technical documentation that answer it.

# gemini settings — used when provider=gemini
# ATOMIRA_GEMINI_API_KEY=
# ATOMIRA_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
